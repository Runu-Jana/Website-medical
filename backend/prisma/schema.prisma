// PostgreSQL schema for DCare (migrated from MongoDB/Mongoose).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  name             String    @default("Customer")
  email            String?   @unique
  password         String?
  role             String    @default("customer")
  phone            String    @default("")
  avatar           String    @default("")
  address          Json?
  cart             Json?
  wishlist         Json?
  trustedDevices   Json?
  loginCount       Int       @default(0)
  lastLoginAt      DateTime?
  isMember         Boolean   @default(false)
  memberSince      DateTime?
  resetCodeHash    String?
  resetCodeExpires DateTime?
  orders           Order[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([phone])
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String    @default("")
  image       String    @default("")
  icon        String    @default("")
  featured    Boolean   @default(false)
  products    Product[] @relation("ProductCategories")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Brand {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  logo      String    @default("")
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                   String     @id @default(uuid())
  name                 String
  slug                 String     @unique
  sku                  String     @default("")
  description          String     @default("")
  shortDescription     String     @default("")
  price                Float      @default(0)
  oldPrice             Float      @default(0)
  discountPercent      Float      @default(0)
  images               String[]
  thumbnail            String     @default("")
  brand                Brand?     @relation(fields: [brandId], references: [id])
  brandId              String?
  categories           Category[] @relation("ProductCategories")
  countInStock         Int        @default(0)
  unit                 String     @default("pcs")
  variants             Json?
  isFeatured           Boolean    @default(false)
  isBestSeller         Boolean    @default(false)
  isNewArrival         Boolean    @default(false)
  isDeal               Boolean    @default(false)
  dealEndsAt           DateTime?
  requiresPrescription Boolean    @default(false)
  isTrending           Boolean    @default(false)
  tags                 String[]
  rating               Float      @default(0)
  numReviews           Int        @default(0)
  reviews              Json?
  sold                 Int        @default(0)
  status               String     @default("active")

  // Catalog / pharma details
  genericName     String @default("")
  manufacturer    String @default("")
  subCategory     String @default("")
  hsnCode         String @default("")
  gstPercent      Float  @default(0)
  purchasePrice   Float  @default(0)
  discountAmount  Float  @default(0)
  minStock        Int    @default(0)
  packSize        String @default("")
  refillDays      Int    @default(0)
  saltComposition String @default("")
  strength        String @default("")
  dosageForm      String @default("")
  uses            String @default("")
  benefits        String @default("")
  sideEffects     String @default("")
  directions      String @default("")
  storage         String @default("")
  dosAndDonts     String @default("")
  faqs            Json? // [{ question, answer }] — AI-generated or admin-authored

  // SEO
  seoTitle        String @default("")
  metaDescription String @default("")
  metaKeywords    String @default("")

  // Marketplace vendor
  vendorId   String @default("")
  vendorName String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([brandId])
}

model Order {
  id                String    @id @default(uuid())
  user              User?     @relation(fields: [userId], references: [id])
  userId            String?
  orderNumber       String?
  items             Json?
  shippingAddress   Json?
  paymentMethod     String    @default("Cash on Delivery")
  razorpayOrderId   String?
  razorpayPaymentId String?
  itemsPrice        Float     @default(0)
  shippingPrice     Float     @default(0)
  discountPrice     Float     @default(0)
  couponCode        String    @default("")
  couponDiscount    Float     @default(0)
  taxPrice          Float     @default(0)
  totalPrice        Float     @default(0)
  isPaid            Boolean   @default(false)
  paidAt            DateTime?
  isRefunded        Boolean   @default(false)
  refundedAt        DateTime?
  refundId          String?
  refundAmount      Float     @default(0)
  isDelivered       Boolean   @default(false)
  deliveredAt       DateTime?
  status            String    @default("pending")
  fulfillmentStatus String    @default("") // packed | verified | ready | dispatched
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

model RefillReminder {
  id          String    @id @default(uuid())
  userId      String
  orderId     String?
  productId   String    @default("")
  productName String    @default("")
  productSlug String    @default("")
  thumbnail   String    @default("")
  dueDate     DateTime
  status      String    @default("scheduled") // scheduled | sent | cancelled
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, dueDate])
  @@index([userId])
}

model Coupon {
  id           String    @id @default(uuid())
  code         String    @unique
  description  String    @default("")
  type         String    @default("percent") // percent | fixed
  value        Float     @default(0) // percent (e.g. 10) or fixed ₹ amount
  maxDiscount  Float     @default(0) // cap for percent coupons (0 = no cap)
  minOrder     Float     @default(0) // minimum cart subtotal to qualify
  scope        String    @default("all") // all | products | categories
  productIds   String[] // when scope = products
  categoryIds  String[] // when scope = categories
  usageLimit   Int       @default(0) // total redemptions allowed (0 = unlimited)
  usedCount    Int       @default(0)
  perUserLimit Int       @default(0) // per-customer redemptions (0 = unlimited)
  startsAt     DateTime?
  endsAt       DateTime?
  active       Boolean   @default(true)
  showOnHome   Boolean   @default(false) // surface on the storefront homepage
  stackable    Boolean   @default(true) // combine with member/deal discounts
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([active])
}

model CouponRedemption {
  id        String   @id @default(uuid())
  couponId  String
  code      String   @default("")
  userId    String?
  orderId   String?
  amount    Float    @default(0)
  createdAt DateTime @default(now())

  @@index([couponId])
  @@index([userId])
}

model SavedView {
  id        String   @id @default(uuid())
  name      String
  scope     String   @default("orders") // which admin page this view belongs to
  config    Json // { status, filters: { conjunction, conditions } }
  createdAt DateTime @default(now())

  @@index([scope])
}

model Banner {
  id         String   @id @default(uuid())
  title      String
  subtitle   String   @default("")
  badge      String   @default("")
  image      String   @default("")
  bgColor    String   @default("#fbe3ec")
  buttonText String   @default("Shop Now")
  link       String   @default("/shop")
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SupportChat {
  id        String   @id @default(uuid())
  userId    String?
  name      String   @default("")
  contact   String   @default("") // email/phone the customer gave (for follow-up)
  messages  Json // [{ role, content, at }]
  escalated Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([escalated])
  @@index([createdAt])
}

model Doctor {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  photo          String   @default("")
  specialty      String   @default("")
  qualifications String   @default("") // e.g. "MBBS, MD - General Physician"
  experience     Int      @default(0) // years
  languages      String[]
  fee            Float    @default(0) // headline consultation fee
  videoFee       Float    @default(0)
  audioFee       Float    @default(0)
  chatFee        Float    @default(0)
  about          String   @default("")
  rating         Float    @default(0)
  numReviews     Int      @default(0)
  active         Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([active])
  @@index([specialty])
}

model Appointment {
  id               String   @id @default(uuid())
  doctorId         String
  doctorName       String   @default("")
  specialty        String   @default("")
  userId           String?
  patientName      String   @default("")
  patientPhone     String   @default("")
  patientEmail     String   @default("")
  consultationType String   @default("video") // video | audio | chat
  fee              Float    @default(0)
  preferredDate    String   @default("")
  preferredTime    String   @default("")
  note             String   @default("")
  status           String   @default("pending") // pending | confirmed | completed | cancelled
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([userId])
}

model PopupBanner {
  id         String   @id @default(uuid())
  title      String   @default("")
  subtitle   String   @default("")
  badge      String   @default("")
  image      String   @default("")
  bgColor    String   @default("#0e9f8e")
  buttonText String   @default("Shop Now")
  link       String   @default("/shop")
  couponCode String   @default("") // optional — shows a copy-to-clipboard chip
  order      Int      @default(0)
  active     Boolean  @default(true)
  frequency  String   @default("session") // session | daily | always
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active])
}

model Prescription {
  id        String   @id @default(uuid())
  name      String   @default("")
  phone     String   @default("")
  note      String   @default("")
  fileUrl   String   @default("")
  userId    String?
  status    String   @default("pending") // pending, reviewed, quoted, completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Post {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  excerpt   String   @default("")
  content   String   @default("")
  image     String   @default("")
  category  String   @default("Health")
  author    String   @default("DCare Team")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  type      String   @default("info") // order | user | prescription | stock | message
  title     String
  message   String   @default("")
  link      String   @default("")
  read      Boolean  @default(false)
  meta      Json?
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}

model Contact {
  id        String   @id @default(uuid())
  name      String   @default("")
  email     String   @default("")
  phone     String   @default("")
  subject   String   @default("")
  message   String   @default("")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}
