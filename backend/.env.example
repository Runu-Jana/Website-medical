# Server
PORT=5000
NODE_ENV=development

# Database — PostgreSQL connection string (Prisma).
# Local:   postgresql://postgres:postgres@localhost:5432/dcare?schema=public
# Neon/Supabase:   postgresql://USER:PASSWORD@HOST/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dcare?schema=public

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=30d

# CORS — comma separated list of allowed origins (storefront + admin)
CLIENT_URLS=http://localhost:5173,http://localhost:5174

# Upload limit in bytes (default 1GB for high resolution imagery)
MAX_UPLOAD_BYTES=1073741824

# Default admin account created by the seeder
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@dcare.com
ADMIN_PASSWORD=admin123

# ── Phone OTP login (Firebase Phone Auth) ──────────────────────────────
# Service-account credentials (Firebase console → Project settings → Service accounts).
# Leave blank to disable Firebase and use dev mode below.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Dev/test mode: when true and Firebase is not configured, the backend accepts
# OTP_DEV_CODE (default 123456) so you can test phone login without sending SMS.
OTP_DEV_MODE=true
OTP_DEV_CODE=123456

# ── Razorpay online payments ──────────────────────────────────────────
# Dashboard → Settings → API Keys. Use rzp_test_ keys to test (no KYC needed).
# Leave blank to keep only Cash on Delivery.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret (Dashboard → Settings → Webhooks) for server-to-server
# payment confirmation. Point the webhook at /api/payments/webhook.
RAZORPAY_WEBHOOK_SECRET=

# ── Email notifications (SMTP) ────────────────────────────────────────
# Emails the admin when a new member joins. Leave blank to disable email
# (in-app bell notifications still work). Switching providers is just these
# values — no code change.
#
# RECOMMENDED — Brevo (free 300 emails/day, good deliverability):
#   1. Sign up at brevo.com
#   2. Verify a sender: Senders, Domains & IPs → Senders → Add & verify
#   3. SMTP & API → SMTP tab → copy the login + generate an SMTP key
#   SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587
#   SMTP_USER=<your Brevo login email>   SMTP_PASS=<your Brevo SMTP key>
#   SMTP_FROM must use your VERIFIED sender address.
#
# GOING FORWARD (India / at scale) — Zoho ZeptoMail (INR + GST, India data
# centre, better deliverability). Requires a verified sender/domain:
#   SMTP_HOST=smtp.zeptomail.in  SMTP_PORT=587
#   SMTP_USER=emailapikey        SMTP_PASS=<ZeptoMail SMTP token>
#
# Alternative — Gmail (App Password, needs 2FA on):
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=<app-password>
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From address — for Brevo this MUST be a verified sender.
SMTP_FROM=DCare <no-reply@dcare.com>
# Where activity emails are sent (defaults to ADMIN_EMAIL above if blank).
NOTIFY_EMAIL=

# ── Image storage (Cloudinary) ────────────────────────────────────────
# In production, local /uploads is wiped on redeploy. Set Cloudinary creds
# (free tier) so product images persist. Leave blank to use local disk in dev.
# Get these from cloudinary.com → Dashboard. Either set CLOUDINARY_URL:
#   CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# ...or the three separate values:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
