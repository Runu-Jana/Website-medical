{
  "name": "dcare-backend",
  "version": "1.0.0",
  "description": "DCare medical & pharmacy eCommerce - PostgreSQL (Prisma) backend API",
  "main": "server.js",
  "type": "module",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "node seed/seed.js",
    "seed:destroy": "node seed/seed.js --destroy"
  },
  "keywords": [
    "ecommerce",
    "medical",
    "pharmacy",
    "postgresql",
    "prisma"
  ],
  "author": "Freelance Web Developer",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.1",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.3.1",
    "helmet": "^7.1.0",
    "imagekit": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nodemailer": "^6.9.14",
    "prisma": "^5.18.0",
    "razorpay": "^2.9.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
