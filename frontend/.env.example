# API base URL — your backend.
#   Local dev:   http://localhost:5000
#   Production:  https://<your-backend>.onrender.com   (set this before building
#                the storefront to upload to Hostinger)
VITE_API_URL=http://localhost:5000

# ── Firebase Phone Auth (optional) ──────────────────────────────
# From Firebase console → Project settings → General → Your web app config.
# Leave blank to use dev mode (no SMS; backend accepts code 123456).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
